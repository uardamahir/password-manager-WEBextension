{
  "manifest_version": 3,
  "name": "Aegis — Local Password Manager",
  "version": "1.0.0",
  "description": "Local-only password manager built on the Web Crypto API. Learning/demo project — do not store real-world secrets in it.",
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aegis",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "host_permissions": ["https://api.pwnedpasswords.com/*"],
  "minimum_chrome_version": "102"
}
